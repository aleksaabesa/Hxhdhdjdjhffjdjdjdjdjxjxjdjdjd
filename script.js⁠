// უსაფრთხოების მიზნით, ეს გასაღები მხოლოდ სატესტოდ გამოიყენეთ!
const FAL_KEY = "b4a014f9-a51c-48a3-89bb-2c8bc939f659:7d1f82cc66411dac340a83ca18b0092e";

document.getElementById('generateBtn').addEventListener('click', async () => {
    const dreamText = document.getElementById('dreamInput').value.trim();
    
    if (!dreamText) {
        alert('გთხოვთ, ჯერ ჩაწეროთ თქვენი სიზმარი!');
        return;
    }

    const loadingDiv = document.getElementById('loading');
    const videoContainer = document.getElementById('videoContainer');
    const dreamVideo = document.getElementById('dreamVideo');

    // ეკრანის მომზადება
    loadingDiv.classList.remove('hidden');
    videoContainer.classList.add('hidden');

    try {
        // 1. ვუგზავნით მოთხოვნას fal.ai-ს ვიდეო გენერაციის დასაწყებად (Luma Dream Machine მოდელი)
        const response = await fetch("https://queue.fal.run/fal-ai/luma-dream-machine", {
            method: "POST",
            headers: {
                "Authorization": `Key ${FAL_KEY}`,
                "Content-Type": "application/json"
            },
            body: JSON.stringify({
                prompt: dreamText,
                aspect_ratio: "16:9",
                loop: false // თუ გინდათ, რომ წრიულად დატრიალდეს ვიდეო, ჩაწერეთ true
            })
        });

        if (!response.ok) {
            throw new Error('fal.ai-სთან კავშირი ვერ დამყარდა');
        }

        const queueData = await response.json();
        const requestId = queueData.request_id;

        // 2. რადგან ვიდეოს გენერაციას დრო სჭირდება, ვიწყებთ პერიოდულ შემოწმებას (Polling)
        // სანამ ვიდეო არ მომზადდება, კოდი ამოწმებს სტატუსს ყოველ 5 წამში ერთხელ
        let videoUrl = null;
        while (!videoUrl) {
            // ველოდებით 5 წამს ყოველ შემოწმებაზე
            await new Promise(resolve => setTimeout(resolve, 5000));

            const statusResponse = await fetch(`https://queue.fal.run/fal-ai/luma-dream-machine/requests/${requestId}`, {
                headers: {
                    "Authorization": `Key ${FAL_KEY}`
                }
            });

            const statusData = await statusResponse.json();

            if (statusData.status === "COMPLETED") {
                // ვიდეო წარმატებით დაგენერირდა!
                videoUrl = statusData.video.url;
            } else if (statusData.status === "FAILED") {
                throw new Error('ვიდეოს გენერაცია ჩაიშალა მოდელის მხარეს');
            }
        }
        
        // 3. შედეგის ჩვენება ეკრანზე
        dreamVideo.src = videoUrl; 
        dreamVideo.load();

        loadingDiv.classList.add('hidden');
        videoContainer.classList.remove('hidden');

    } catch (error) {
        console.error('შეცდომა:', error);
        alert('ვიდეოს გენერაციისას დაფიქსირდა ტექნიკური ხარვეზი. გთხოვთ, სცადოთ ცოტა მოგვიანებით.');
        loadingDiv.classList.add('hidden');
    }
});
